! Project configuration
&config_project
  ! Project name
  project_details = "mHM project"
  ! Description of the setup
  setup_description = "Model run"
  ! Type of simulation
  simulation_type = "Simulation"
  ! Convention used for dataset
  Conventions = "None"
  ! Contact details, incl. PI name, modellers
  contact = "Developer"
  ! Developing institution
  mHM_details = "Research unit"
  ! Some details on data/model run version.
  history = "Model run version 1"
  ! Number of domains
  n_domains = 1
  ! Flag for separate domains
  read_domains_from_dirs = .false.
  ! Domain directories
  domain_dirs(:) = ""
/

! Processes configuration
&config_processes
  ! Interception process case
  interception = 1
  ! Snow process case
  snow = 1
  ! Soil moisture process case
  soil_moisture = 1
  ! Direct runoff process case
  direct_runoff = 1
  ! Potential evapotranspiration (PET) process case
  pet = -2
  ! Interflow process case
  interflow = 1
  ! Percolation process case
  percolation = 1
  ! Baseflow process case
  baseflow = 1
  ! Ground albedo of cosmic-ray neutrons process case
  neutrons = 0
  ! Routing process case
  routing = 3
  ! River temperature routing process case
  temperature_routing = 0
/

! Optimization configuration
&config_optimize
  ! Enable optimization
  optimize = .false.
  ! Restart optimization
  optimize_restart = .false.
  ! Optimization method
  opti_method = 1
  ! Objective function to be optimized
  opti_function = 10
  ! Number of iterations
  iterations = 7
  ! Seed
  seed = 1235876
  ! DDS perturbation rate
  dds_r = 0.2
  ! Initial Temperature
  sa_temp = -9.0
  ! Number of SCE Complexes
  sce_ngs = 2
  ! Points per SCE Complex
  sce_npg = -9
  ! Points per SCE Sub-Complex
  sce_nps = -9
  ! MCMC for optimisation
  mcmc_opti = .false.
  ! Parameters of MCMC error model.
  mcmc_error_params(:) = 0.01, 0.6
  ! Calculate BFI from discharge time series with the Eckhardt filter
  BFI_calc = .true.
/

! Time configuration
&config_time
  ! Simulation start
  sim_start(:) = "2020-06-01 00:00"
  ! Evaluation start
  eval_start(:) = "2021-01-01 00:00"
  ! Simulation end
  sim_end(:) = "2022-01-01 00:00"
  ! Share time period between domains
  share_time_period = .false.
  ! Time step of the simulation
  time_step(:) = 1
  ! Share time step between domains
  share_time_step = .true.
/

! Input configuration
&config_input
  ! Chunking for input data
  chunking(:) = 0
  ! NetCDF time-stamp location
  time_stamp_location(:) = 0
  ! Latlon specification file path
  latlon_path(:) = ""
  ! DEM in latlon coordinates
  morph_latlon(:) = .false.
  ! Precipitation input
  pre_path(:) = ""
  ! Potential evapotranspiration input
  pet_path(:) = ""
  ! Air temperature input
  temp_path(:) = ""
  ! Air temperature annual mean input
  tann_path(:) = ""
  ! Air temperature daily minimum input
  tmin_path(:) = ""
  ! Air temperature daily maximum input
  tmax_path(:) = ""
  ! Surface shortwave radiation downwards input
  ssrd_path(:) = ""
  ! Surface thermal radiation downwards input
  strd_path(:) = ""
  ! Net radiation input
  netrad_path(:) = ""
  ! Vapor pressure input
  eabs_path(:) = ""
  ! Wind speed input
  wind_path(:) = ""
  ! Meteorological mask file path
  meteo_mask_path(:) = ""
  ! Runoff input
  runoff_path(:) = ""
  ! Sealed runoff input
  runoff_sealed_path(:) = ""
  ! Fast interflow input
  interflow_fast_path(:) = ""
  ! Slow interflow input
  interflow_slow_path(:) = ""
  ! Baseflow input
  baseflow_path(:) = ""
  ! Hydrological mask file path
  hydro_mask_path(:) = ""
  ! DEM input
  dem_path(:) = ""
  ! Slope input
  slope_path(:) = ""
  ! Aspect input
  aspect_path(:) = ""
  ! Flow direction input
  fdir_path(:) = ""
  ! Flow accumulation input
  facc_path(:) = ""
  ! Geology class input
  geo_class_path(:) = ""
  ! Soil class input
  soil_class_path(:) = ""
  ! Soil horizon class input
  soil_horizon_class_path(:) = ""
  ! LAI class input
  lai_class_path(:) = ""
  ! River width input
  river_width_path(:) = ""
  ! Morphology mask file path
  morph_mask_path(:) = ""
  ! Precipitation variable name
  pre_var(:) = "pre"
  ! Potential evapotranspiration variable name
  pet_var(:) = "pet"
  ! Air temperature variable name
  temp_var(:) = "tavg"
  ! Air temperature annual mean variable name
  tann_var(:) = "tann"
  ! Air temperature daily minimum variable name
  tmin_var(:) = "tmin"
  ! Air temperature daily maximum variable name
  tmax_var(:) = "tmax"
  ! Surface shortwave radiation variable name
  ssrd_var(:) = "ssrd"
  ! Surface thermal radiation variable name
  strd_var(:) = "strd"
  ! Net radiation variable name
  netrad_var(:) = "net_rad"
  ! Vapor pressure variable name
  eabs_var(:) = "eabs"
  ! Wind speed variable name
  wind_var(:) = "windspeed"
  ! Meteorological mask variable name
  meteo_mask_var(:) = "mask"
  ! Runoff variable name
  runoff_var(:) = "runoff"
  ! Sealed runoff variable name
  runoff_sealed_var(:) = "runoff_sealed"
  ! Fast interflow variable name
  interflow_fast_var(:) = "interflow_fast"
  ! Slow interflow variable name
  interflow_slow_var(:) = "interflow_slow"
  ! Baseflow variable name
  baseflow_var(:) = "baseflow"
  ! Hydrological mask variable name
  hydro_mask_var(:) = "mask"
  ! DEM variable name
  dem_var(:) = "dem"
  ! Slope variable name
  slope_var(:) = "slope"
  ! Aspect variable name
  aspect_var(:) = "aspect"
  ! Flow direction variable name
  fdir_var(:) = "fdir"
  ! Flow accumulation variable name
  facc_var(:) = "facc"
  ! Geology class variable name
  geo_class_var(:) = "geology_class"
  ! Soil class variable name
  soil_class_var(:) = "soil_class"
  ! LAI class variable name
  lai_class_var(:) = "LAI_class"
  ! River width variable name
  river_width_var(:) = "P_bkfl"
  ! Morphology mask variable name
  morph_mask_var(:) = "mask"
  ! Hydrological latitude variable name
  hydro_lat_var(:) = "lat"
  ! Hydrological longitude variable name
  hydro_lon_var(:) = "lon"
  ! Morphology latitude variable name
  morph_lat_var(:) = "lat_l0"
  ! Morphology longitude variable name
  morph_lon_var(:) = "lon_l0"
  ! Routing latitude variable name
  route_lat_var(:) = "lat_l11"
  ! Routing longitude variable name
  route_lon_var(:) = "lon_l11"
/

! Coupling configuration
&config_coupling
  ! Meteo grid size in x-direction
  meteo_grid_nx(:) = 0
  ! Meteo grid size in y-direction
  meteo_grid_ny(:) = 0
  ! Meteo grid x origin
  meteo_grid_xll(:) = 0.0
  ! Meteo grid y origin
  meteo_grid_yll(:) = 0.0
  ! Meteo grid cell size
  meteo_grid_cellsize(:) = 0.0
  ! Meteo grid y direction
  meteo_grid_ydir(:) = 0
  ! Meteo grid coordinate system
  meteo_grid_coordsys(:) = 0
  ! Hydro grid size in x-direction
  hydro_grid_nx(:) = 0
  ! Hydro grid size in y-direction
  hydro_grid_ny(:) = 0
  ! Hydro grid x origin
